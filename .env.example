# ── Grading ───────────────────────────────────────────────────────────────
# Gemini does the grading. Without it the exam loads but cannot score.
GEMINI_API_KEY=

# ── Accounts + employer results (Supabase) ────────────────────────────────
# Optional: the site builds and the exam renders without these, but sign-in
# and the employer dashboard are disabled. Run supabase-judgemynt.sql once.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Employer contact form (Resend) ────────────────────────────────────────
# Optional: without a key the form accepts and no-ops instead of erroring.
RESEND_API_KEY=
# Until a domain is verified in Resend, onboarding@resend.dev is the only
# sender that will actually deliver.
EMAIL_FROM=Judgemynt <onboarding@resend.dev>
CONTACT_EMAIL=judgemynt@gmail.com
