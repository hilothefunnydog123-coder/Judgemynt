# ── Grading ───────────────────────────────────────────────────────────────
# Gemini does the grading. Without it the exam loads but cannot score.
GEMINI_API_KEY=

# ── Accounts + employer results (Supabase) ────────────────────────────────
# Optional: the site builds and the exam renders without these, but sign-in
# and the employer dashboard are disabled. Run supabase-judgemynt.sql once.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google sign-in (OAuth) runs through Supabase Auth. One-time setup:
#   1. Google Cloud Console -> APIs & Services -> Credentials -> create an
#      OAuth 2.0 Client ID (type: Web application).
#      Authorized redirect URI: https://<project-ref>.supabase.co/auth/v1/callback
#   2. Supabase dashboard -> Authentication -> Providers -> Google: enable it
#      and paste the Client ID and Client Secret.
#   3. Supabase dashboard -> Authentication -> URL Configuration: set Site URL
#      to your deployed domain and add http://localhost:3000 to Redirect URLs
#      for local dev.
# No extra env vars are needed here; the anon key above is enough.

# ── Employer contact form (Resend) ────────────────────────────────────────
# Optional: without a key the form accepts and no-ops instead of erroring.
RESEND_API_KEY=
# Until a domain is verified in Resend, onboarding@resend.dev is the only
# sender that will actually deliver.
EMAIL_FROM=Judgemynt <onboarding@resend.dev>
CONTACT_EMAIL=judgemynt@gmail.com
